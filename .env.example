# PocketID / OIDC settings
# NOTE: docker-compose.yml sets OAUTH2_PROXY_EMAIL_DOMAINS=* (accept any domain).
# This is ONLY safe with a private OIDC provider like self-hosted PocketID.
# If you change OIDC_ISSUER_URL to a public provider (Google, GitHub, etc.),
# you MUST also restrict OAUTH2_PROXY_EMAIL_DOMAINS to a specific domain.
OIDC_ISSUER_URL=https://your-pocketid-instance.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# The public URL where this app is accessible (no trailing slash)
PUBLIC_URL=https://jobs.example.com

# Generate with: openssl rand -base64 32 | tr -- '+/' '-_'
COOKIE_SECRET=

# External port to listen on (default 3000)
LISTEN_PORT=3000

# Set to false if not using HTTPS (e.g. local dev)
COOKIE_SECURE=true

# Comma-separated list of admin email addresses (can view all users' applications)
ADMIN_EMAILS=admin@example.com

# Rate limiting (requests per minute per IP, optional — defaults shown)
# RATE_LIMIT_API=100
# RATE_LIMIT_UPLOADS=20

# SMB File Access (optional)
# Set ENABLE_SMB=true to start Samba and the sync engine
ENABLE_SMB=false
SMB_USER=ferg
# SMB_PASS via env or use SMB_CREDENTIALS_FILE instead (format: username:password:email)
# SMB_PASS=
SMB_USER_EMAIL=ferg@example.com
# SMB_CREDENTIALS_FILE=/run/secrets/smb-credentials
